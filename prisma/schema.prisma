generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Phase 0-1: System Access & Organization ──────────────────────

enum SystemRole {
  SUPER_ADMIN
  SYSTEM_ADMIN
  EXECUTIVE
  DEPT_MANAGER
  TEAM_LEADER
  OPERATIONS_MANAGER
  HR
  STAFF
  VA
}

enum UserType {
  INTERNAL_STAFF
  VIRTUAL_ASSISTANT
}

enum TemporaryRole {
  CONTRIBUTOR
  VIEWER
  APPROVER
}

// ── Phase 2: VA Workforce ────────────────────────────────────────

enum ContractType {
  REGULAR
  PROJECT_BASED
  PROBATIONARY
}

enum EmploymentStatus {
  EMPLOYED
  ENGAGED
  CONTRACTED
  END_OF_CONTRACT
  TRANSFERRED
  RESIGNED
  TERMINATED
  BLACKLISTED
}

enum HistoryEventType {
  STATUS_CHANGE
  ENGAGEMENT_CHANGE
  UPSKILL
  RATE_CHANGE
  PROMOTION
  DEPARTMENT_TRANSFER
}

enum TransferType {
  ACTIVE
  END_OF_CONTRACT
  HYBRID
}

enum Availability {
  AVAILABLE
  PARTIALLY_ASSIGNED
  FULLY_ASSIGNED
  ON_LEAVE
  UNAVAILABLE
}

enum Proficiency {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum LeaveType {
  VACATION
  SICK
  EMERGENCY
  MATERNITY
  PATERNITY
  UNPAID
  BEREAVEMENT
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum DocumentType {
  CONTRACT
  GOVERNMENT_ID
  NDA
  CLEARANCE
  CERTIFICATE
  ONBOARDING
  PERFORMANCE_REVIEW
  PORTFOLIO
  FOLDER_201
  FILE_201
  VA_CLIENT_FILE
  HEALTH_CHECK
  VA_PROFILE
  PAYOUT_SUMMARY
  DEPT_201_FOLDER
  OTHER
}

// ── Phase 3: Clients ─────────────────────────────────────────────

enum AssignmentType {
  REGULAR
  PROJECT
}

enum AssignmentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
  ON_HOLD
}

enum AssignmentSource {
  MANUAL
  VA_CONNECTIONS_SYNC
}

enum SkillCategory {
  STANDARD
  UPSKILL
  SPECIAL
}

enum ClientPlatform {
  AMAZON
  WALMART
  TIKTOK_SHOP
  SHOPIFY
  MULTI
}

// ── Phase 4: Ticketing ───────────────────────────────────────────

enum TicketCategory {
  TECHNICAL
  HR
  CLIENT
  VA_SUPPORT
  GENERAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_CLIENT
  RESOLVED
  CLOSED
}

enum TicketSource {
  INTERNAL
  EMAIL
  WHATSAPP
  CLIENT_PORTAL
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ── Audit ────────────────────────────────────────────────────────

enum NotificationType {
  NEW_ASSIGNMENT
  HOURS_SHORTFALL
  NEW_MESSAGE
  MESSAGE_REPLY
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  TRANSFER
  APPROVE
  REJECT
  FILE_UPLOAD
  SIGN_IN
  SIGN_OUT
  MEMBER_ADD
  MEMBER_REMOVE
  ROLE_CHANGE
  LOGIN_FAILED
}

// ── Departments ──────────────────────────────────────────────────

enum DepartmentStatus {
  ACTIVE
  MERGED
  SPLIT
  INACTIVE
}

enum DepartmentLevel {
  EXECUTIVE
  MANAGEMENT
  SERVICE
}

enum GeneralStatus {
  ACTIVE
  PENDING
  TRANSFERRED
  RESIGNED
  REMOVED
  PROJECT_ENDED
  CANCELLED
  BLACKLISTED
  UNIDENTIFIED
}

// ──────────────────────────────────────────────────────────────────
// MODELS — Phase 0-1: Core Organization
// ──────────────────────────────────────────────────────────────────

model Department {
  id           String           @id @default(cuid())
  name         String
  shortName    String?          @map("short_name")
  acronym      String?
  level        DepartmentLevel?
  status       DepartmentStatus @default(ACTIVE)
  parentId     String?          @map("parent_id")
  parent       Department?      @relation("DeptHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children     Department[]     @relation("DeptHierarchy")
  mergedIntoId String?          @map("merged_into_id")
  mergedInto   Department?      @relation("DepartmentMerge", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedFrom   Department[]     @relation("DepartmentMerge")
  splitFromId  String?          @map("split_from_id")
  splitFrom    Department?      @relation("DepartmentSplit", fields: [splitFromId], references: [id], onDelete: SetNull)
  splitInto    Department[]     @relation("DepartmentSplit")
  isParent     Boolean          @default(false) @map("is_parent")
  description  String?
  headId       String?          @map("head_id")
  head         User?            @relation("DeptHead", fields: [headId], references: [id], onDelete: SetNull)
  sortOrder    Int              @default(0) @map("sort_order")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  memberships       DepartmentMembership[]
  positions         Position[]
  clients           Client[]
  tickets           Ticket[]
  auditLogs         AuditLog[]
  roleAssignments   RoleAssignment[]
  services          DepartmentSkill[]
  vaHistoryEvents   VAHistory[]
  employmentRecords EmploymentRecord[]
  channel           Channel?
  teams             Team[]                 @relation("DepartmentTeams")

  @@unique([name, parentId])
  @@unique([acronym, parentId])
  @@map("departments")
}

model Position {
  id           String        @id @default(cuid())
  title        String
  reportsToId  String?       @map("reports_to_id")
  reportsTo    Position?     @relation("PositionChain", fields: [reportsToId], references: [id], onDelete: SetNull)
  subordinates Position[]    @relation("PositionChain")
  departmentId String?       @map("department_id")
  department   Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  isStaffRole  Boolean       @default(false) @map("is_staff_role")
  sortOrder    Int           @default(0) @map("sort_order")
  status       GeneralStatus @default(ACTIVE) @map("general_status")
  onHold       Boolean       @default(false) @map("on_hold")
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  memberships DepartmentMembership[]

  @@map("positions")
}

model DepartmentMembership {
  id                String                 @id @default(cuid())
  userId            String                 @map("user_id")
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId      String                 @map("department_id")
  department        Department             @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  positionId        String?                @map("position_id")
  position          Position?              @relation(fields: [positionId], references: [id], onDelete: SetNull)
  isPrimary         Boolean                @default(false) @map("is_primary")
  hourlyRate        Decimal?               @map("hourly_rate")
  baseRate          Decimal?               @map("base_rate")
  transferType      TransferType?          @map("transfer_type")
  transferredFromId String?                @map("transferred_from_id")
  transferredFrom   DepartmentMembership?  @relation("MembershipTransferChain", fields: [transferredFromId], references: [id], onDelete: SetNull)
  transferredTo     DepartmentMembership[] @relation("MembershipTransferChain")
  startedAt         DateTime               @default(now()) @map("started_at")
  endedAt           DateTime?              @map("ended_at")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")

  @@index([userId, departmentId])
  @@map("department_memberships")
}

// ──────────────────────────────────────────────────────────────────
// MODELS — Phase 0-1: Users & Personnel
// ──────────────────────────────────────────────────────────────────

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  firstName    String        @map("first_name")
  middleName   String?       @map("middle_name")
  lastName     String        @map("last_name")
  extName      String?       @map("ext_name")
  systemRole   SystemRole    @map("system_role")
  userType     UserType      @map("user_type")
  avatarUrl    String?       @map("avatar_url")
  messageColor MessageColor  @default(BLUE) @map("message_color")
  status       GeneralStatus @default(ACTIVE) @map("general_status")
  onHold       Boolean       @default(false) @map("on_hold")
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  profile                    UserProfile?
  vaProfile                  VAProfile?
  departmentHead             Department[]           @relation("DeptHead")
  memberships                DepartmentMembership[]
  employmentRecords          EmploymentRecord[]
  employmentRecordsInitiated EmploymentRecord[]     @relation("EmploymentInitiator")
  roleAssignments            RoleAssignment[]
  grantedRoleAssignments     RoleAssignment[]       @relation("RoleGranter")
  leaveRequests              LeaveRequest[]         @relation("LeaveRequestor")
  approvedLeaves             LeaveRequest[]         @relation("LeaveApprover")
  managedClients             Client[]               @relation("ClientManager")
  uploadedDocuments          VADocument[]           @relation("DocUploader")
  createdTickets             Ticket[]               @relation("TicketCreator")
  assignedTickets            Ticket[]               @relation("TicketAssignee")
  ticketConversations        TicketConversation[]
  auditLogs                  AuditLog[]
  vaHistoryEvents            VAHistory[]            @relation("VAHistoryUser")
  vaHistoryChanges           VAHistory[]            @relation("VAHistoryChangedBy")
  notifications              Notification[]
  sidebarFavorites           SidebarFavorite[]
  messages                   Message[]
  messageMentions            MessageMention[]
  channelReads               ChannelRead[]
  pinnedMessages             Message[]              @relation("MessagePinnedBy")
  channelParticipants        ChannelParticipant[]
  ledTeams                   Team[]                 @relation("TeamLeader")
  tempLedTeams1              Team[]                 @relation("TeamTempLeader1")
  tempLedTeams2              Team[]                 @relation("TeamTempLeader2")
  teamMemberships            TeamMembership[]       @relation("TeamMember")

  @@index([email])
  @@index([systemRole])
  @@index([userType])
  @@map("users")
}

model UserProfile {
  id                       String    @id @default(cuid())
  userId                   String    @unique @map("user_id")
  user                     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone                    String?
  whatsappNumber           String?   @map("whatsapp_number")
  gender                   String?
  birthDate                DateTime? @map("birth_date")
  nonCelebrant             Boolean   @default(false) @map("non_celebrant")
  birthdayCelebrant        Boolean   @default(true) @map("birthday_celebrant")
  barangay                 String?
  cityMunicipality         String?   @map("city_municipality")
  province                 String?
  zipCode                  String?   @map("zip_code")
  landmark                 String?
  address                  String?
  addressLine              String?   @map("address_line")
  emergencyContactName     String?   @map("emergency_contact_name")
  emergencyContactPhone    String?   @map("emergency_contact_phone")
  emergencyContactRelation String?   @map("emergency_contact_relation")
  gcashNumber              String?   @map("gcash_number")
  personalEmail            String?   @map("personal_email")
  workEmail                String?   @map("work_email")
  regionCode               String?   @map("region_code")
  provinceCode             String?   @map("province_code")
  cityCode                 String?   @map("city_code")
  barangayCode             String?   @map("barangay_code")
  facebookName             String?   @map("facebook_name")
  facebookUrl              String?   @map("facebook_url")
  linkedinUrl              String?   @map("linkedin_url")
  payoneerAccount          String?   @map("payoneer_account")
  passportNumber           String?   @map("passport_number")
  passportPhoto            String?   @map("passport_photo")
  philhealthNumber         String?   @map("philhealth_number")
  philhealthPhoto          String?   @map("philhealth_photo")
  signedContract           String?   @map("signed_contract")
  personalityTraits        String[]  @map("personality_traits")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  @@map("user_profiles")
}

model EmploymentRecord {
  id               String           @id @default(cuid())
  userId           String           @map("user_id")
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId     String?          @map("department_id")
  department       Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  contractType     ContractType     @map("contract_type")
  employmentStatus EmploymentStatus @map("employment_status")
  startDate        DateTime         @map("start_date")
  endDate          DateTime?        @map("end_date")
  effectiveDate    DateTime         @default(now()) @map("effective_date")
  reason           String?
  initiatedBy      String?          @map("initiated_by")
  initiator        User?            @relation("EmploymentInitiator", fields: [initiatedBy], references: [id], onDelete: SetNull)
  isCurrent        Boolean          @default(true) @map("is_current")
  tenureDays       Int?             @map("tenure_days")
  notes            String?
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@index([userId])
  @@index([employmentStatus])
  @@index([departmentId, startDate])
  @@map("employment_records")
}

model RoleAssignment {
  id           String        @id @default(cuid())
  userId       String        @map("user_id")
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         TemporaryRole
  module       String
  departmentId String?       @map("department_id")
  department   Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  grantedBy    String        @map("granted_by")
  grantor      User          @relation("RoleGranter", fields: [grantedBy], references: [id], onDelete: Cascade)
  expiresAt    DateTime?     @map("expires_at")
  status       GeneralStatus @default(ACTIVE) @map("general_status")
  onHold       Boolean       @default(false) @map("on_hold")
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")

  @@map("role_assignments")
}

// ──────────────────────────────────────────────────────────────────
// MODELS — Phase 2: VA Workforce
// ──────────────────────────────────────────────────────────────────

model VAProfile {
  id                  String            @id @default(cuid())
  userId              String            @unique @map("user_id")
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  hourlyRate          Decimal?          @map("hourly_rate")
  baseRate            Decimal?          @map("base_rate")
  vaaPosition         String?           @map("vaa_position")
  positionSkillId     String?           @map("position_skill_id")
  positionSkill       Skill?            @relation(fields: [positionSkillId], references: [id], onDelete: SetNull)
  level               String?
  availabilityStatus  Availability      @default(AVAILABLE) @map("availability_status")
  recommendability    String?           @map("recommendability")
  totalCapacityHours  Decimal?          @default(40) @map("total_capacity_hours")
  preferredWorkHours  Decimal?          @map("preferred_work_hours")
  availableSchedule   String?           @map("available_schedule")
  hybrid              Boolean           @default(false)
  onboardingFolderUrl String?           @map("onboarding_folder_url")
  portfolioUrl        String?           @map("portfolio_url")
  contractLink        String?           @map("contract_link")
  folder201Link       String?           @map("folder_201_link")
  file201Link         String?           @map("file_201_link")
  vaClientFileLink    String?           @map("va_client_file_link")
  healthCheckFileLink String?           @map("health_check_file_link")
  vaProfileLink       String?           @map("va_profile_link")
  payoutSummaryLink   String?           @map("payout_summary_link")
  dept201FolderLink   String?           @map("dept_201_folder_link")
  notes               String?
  status              GeneralStatus     @default(ACTIVE) @map("general_status")
  onHold              Boolean           @default(false) @map("on_hold")
  engagementStatus    EmploymentStatus? @map("engagement_status")
  currentHireDate     DateTime?         @map("current_hire_date")
  currentEndDate      DateTime?         @map("current_end_date")
  isActive            Boolean           @default(true) @map("is_active")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  assignments Assignment[]
  workLogs    WorkLog[]
  vaSkills    VASkill[]
  documents   VADocument[]

  @@index([availabilityStatus])
  @@index([positionSkillId])
  @@index([currentHireDate])
  @@map("va_profiles")
}

model VAHistory {
  id            String           @id @default(cuid())
  userId        String           @map("user_id")
  user          User             @relation("VAHistoryUser", fields: [userId], references: [id], onDelete: Cascade)
  eventType     HistoryEventType @map("event_type")
  oldValue      String?          @map("old_value")
  newValue      String?          @map("new_value")
  departmentId  String?          @map("department_id")
  department    Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  effectiveDate DateTime         @map("effective_date")
  reason        String?
  changedById   String           @map("changed_by_id")
  changedBy     User             @relation("VAHistoryChangedBy", fields: [changedById], references: [id], onDelete: Cascade)
  createdAt     DateTime         @default(now()) @map("created_at")

  @@index([userId, effectiveDate])
  @@index([eventType, effectiveDate])
  @@map("va_history")
}

model Skill {
  id             String        @id @default(cuid())
  name           String        @unique
  shortName      String?       @map("short_name")
  acronym        String?       @unique
  category       SkillCategory @default(STANDARD)
  jobDescription String?       @map("job_description")
  attachmentUrl  String?       @map("attachment_url")
  isActive       Boolean       @default(true) @map("is_active")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  vaSkills       VASkill[]
  departments    DepartmentSkill[]
  positionForVAs VAProfile[]

  @@map("skills")
}

model DepartmentSkill {
  id           String     @id @default(cuid())
  departmentId String     @map("department_id")
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  skillId      String     @map("skill_id")
  skill        Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([departmentId, skillId])
  @@map("department_skills")
}

model VASkill {
  id              String      @id @default(cuid())
  vaProfileId     String      @map("va_profile_id")
  vaProfile       VAProfile   @relation(fields: [vaProfileId], references: [id], onDelete: Cascade)
  skillId         String      @map("skill_id")
  skill           Skill       @relation(fields: [skillId], references: [id], onDelete: Cascade)
  proficiency     Proficiency @default(INTERMEDIATE)
  yearsExperience Decimal?    @map("years_experience")
  isPrimary       Boolean     @default(false) @map("is_primary")
  createdAt       DateTime    @default(now()) @map("created_at")

  @@unique([vaProfileId, skillId])
  @@map("va_skills")
}

model VADocument {
  id             String       @id @default(cuid())
  vaProfileId    String       @map("va_profile_id")
  vaProfile      VAProfile    @relation(fields: [vaProfileId], references: [id], onDelete: Cascade)
  documentType   DocumentType @map("document_type")
  fileName       String       @map("file_name")
  googleDriveUrl String       @map("google_drive_url")
  mimeType       String?      @map("mime_type")
  fileSize       Int?         @map("file_size")
  uploadedBy     String       @map("uploaded_by")
  uploader       User         @relation("DocUploader", fields: [uploadedBy], references: [id], onDelete: Cascade)
  expiresAt      DateTime?    @map("expires_at")
  notes          String?
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([vaProfileId])
  @@map("va_documents")
}

model LeaveRequest {
  id               String      @id @default(cuid())
  userId           String      @map("user_id")
  user             User        @relation("LeaveRequestor", fields: [userId], references: [id], onDelete: Cascade)
  leaveType        LeaveType   @map("leave_type")
  startDate        DateTime    @map("start_date")
  endDate          DateTime    @map("end_date")
  totalDays        Decimal     @map("total_days")
  reason           String?
  status           LeaveStatus @default(PENDING)
  approverId       String?     @map("approver_id")
  approver         User?       @relation("LeaveApprover", fields: [approverId], references: [id], onDelete: SetNull)
  approvedAt       DateTime?   @map("approved_at")
  approverNote     String?     @map("approver_note")
  notificationSent Boolean     @default(false) @map("notification_sent")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@map("leave_requests")
}

// ──────────────────────────────────────────────────────────────────
// MODELS — Phase 3: Clients & Service Lines
// ──────────────────────────────────────────────────────────────────

model Client {
  id                  String         @id @default(cuid())
  name                String
  contactName         String?        @map("contact_name")
  contactEmail        String?        @map("contact_email")
  contactPhone        String?        @map("contact_phone")
  platform            ClientPlatform @default(MULTI)
  industry            String?
  timezone            String?        @default("America/New_York")
  notes               String?
  status              GeneralStatus  @default(ACTIVE) @map("general_status")
  onHold              Boolean        @default(false) @map("on_hold")
  isActive            Boolean        @default(true) @map("is_active")
  managerId           String?        @map("manager_id")
  manager             User?          @relation("ClientManager", fields: [managerId], references: [id], onDelete: SetNull)
  departmentId        String?        @map("department_id")
  department          Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  onboardingFolderUrl String?        @map("onboarding_folder_url")
  website             String?
  requiredSkills      String[]       @map("required_skills")
  intakeDetails       Json?          @map("intake_details")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  assignments Assignment[]
  tickets     Ticket[]

  @@index([departmentId])
  @@map("clients")
}

model Assignment {
  id                String           @id @default(cuid())
  type              AssignmentType
  status            AssignmentStatus @default(ACTIVE)
  agreedHours       Decimal          @map("agreed_hours")
  monthlyHours      Decimal?         @map("monthly_hours")
  startDate         DateTime         @map("start_date")
  endDate           DateTime?        @map("end_date")
  notes             String?
  skillRequirements String[]         @map("skill_requirements")
  source            AssignmentSource @default(MANUAL)
  externalId        String?          @unique @map("external_id")
  syncedAt          DateTime?        @map("synced_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  vaProfileId String    @map("va_profile_id")
  vaProfile   VAProfile @relation(fields: [vaProfileId], references: [id], onDelete: Cascade)

  clientId String @map("client_id")
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  workLogs WorkLog[]

  @@index([vaProfileId])
  @@index([clientId])
  @@index([status])
  @@map("assignments")
}

model WorkLog {
  id          String   @id @default(cuid())
  workDate    DateTime @map("work_date")
  hours       Decimal
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  vaProfileId String    @map("va_profile_id")
  vaProfile   VAProfile @relation(fields: [vaProfileId], references: [id], onDelete: Cascade)

  assignmentId String     @map("assignment_id")
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([vaProfileId])
  @@index([assignmentId])
  @@index([workDate])
  @@map("work_logs")
}

// ──────────────────────────────────────────────────────────────────
// MODELS — Phase 4: Communications & Ticketing
// ──────────────────────────────────────────────────────────────────

model Ticket {
  id           String         @id @default(cuid())
  ticketNumber String         @unique @map("ticket_number")
  title        String
  description  String?
  category     TicketCategory
  priority     Priority       @default(MEDIUM)
  status       TicketStatus   @default(OPEN)
  source       TicketSource   @default(INTERNAL)
  createdBy    String         @map("created_by")
  creator      User           @relation("TicketCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  assignedTo   String?        @map("assigned_to")
  assignee     User?          @relation("TicketAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  departmentId String?        @map("department_id")
  department   Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  clientId     String?        @map("client_id")
  client       Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  resolvedAt   DateTime?      @map("resolved_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  conversations TicketConversation[]

  @@index([assignedTo])
  @@index([departmentId])
  @@index([status])
  @@map("tickets")
}

model TicketConversation {
  id             String   @id @default(cuid())
  ticketId       String   @map("ticket_id")
  ticket         Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId         String   @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message        String
  isInternalNote Boolean  @default(false) @map("is_internal_note")
  attachments    String[]
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([ticketId, createdAt])
  @@map("ticket_conversations")
}

// ── Phase 5: Messaging ───────────────────────────────────────────

enum ChannelKind {
  DEPARTMENT
  DIRECT
  ANNOUNCEMENTS
}

model Channel {
  id           String      @id @default(cuid())
  kind         ChannelKind @default(DEPARTMENT)
  departmentId String?     @unique @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  dmKey        String?     @unique @map("dm_key")
  createdAt    DateTime    @default(now()) @map("created_at")

  messages     Message[]
  reads        ChannelRead[]
  participants ChannelParticipant[]

  @@map("channels")
}

model ChannelParticipant {
  id        String    @id @default(cuid())
  channelId String    @map("channel_id")
  channel   Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  muted     Boolean   @default(false)
  archived  Boolean   @default(false)
  clearedAt DateTime? @map("cleared_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@unique([channelId, userId])
  @@index([userId])
  @@map("channel_participants")
}

model Message {
  id        String           @id @default(cuid())
  channelId String           @map("channel_id")
  channel   Channel          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  senderId  String           @map("sender_id")
  sender    User             @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body      String
  mentions  MessageMention[]
  createdAt DateTime         @default(now()) @map("created_at")

  editedAt  DateTime? @map("edited_at")
  deletedAt DateTime? @map("deleted_at")

  parentId String?   @map("parent_id")
  parent   Message?  @relation("MessageReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies  Message[] @relation("MessageReplies")

  pinned       Boolean   @default(false)
  pinnedAt     DateTime? @map("pinned_at")
  pinnedBy     String?   @map("pinned_by")
  pinnedByUser User?     @relation("MessagePinnedBy", fields: [pinnedBy], references: [id], onDelete: SetNull)

  forwardedFromId         String? @map("forwarded_from_id")
  forwardedFromBody       String? @map("forwarded_from_body")
  forwardedFromSenderName String? @map("forwarded_from_sender_name")

  @@index([channelId, createdAt])
  @@index([parentId])
  @@index([channelId, pinned])
  @@map("messages")
}

model MessageMention {
  id              String   @id @default(cuid())
  messageId       String   @map("message_id")
  message         Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  mentionedUserId String   @map("mentioned_user_id")
  mentionedUser   User     @relation(fields: [mentionedUserId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([mentionedUserId])
  @@map("message_mentions")
}

model ChannelRead {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId  String   @map("channel_id")
  channel    Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  lastReadAt DateTime @default(now()) @map("last_read_at")

  @@unique([userId, channelId])
  @@map("channel_reads")
}

// ──────────────────────────────────────────────────────────────────
// MODELS — Audit Trail
// ──────────────────────────────────────────────────────────────────

model AuditLog {
  id           String      @id @default(cuid())
  actorId      String      @map("actor_id")
  actor        User        @relation(fields: [actorId], references: [id], onDelete: Cascade)
  action       AuditAction
  entityType   String      @map("entity_type")
  entityId     String      @map("entity_id")
  oldValues    Json?       @map("old_values")
  newValues    Json?       @map("new_values")
  metadata     Json?
  departmentId String?     @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now()) @map("created_at")

  @@index([entityType, entityId, createdAt])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}

// ──────────────────────────────────────────────────────────────────
// MODELS — External Sync (VAConnections Google Sheet import)
// ──────────────────────────────────────────────────────────────────

enum SyncEntityType {
  VA_PROFILE
  CLIENT
}

// Maps the manager's Google Sheet IDs (VAID, ClientID) to this app's
// VAProfile/Client records. Assignment itself doesn't need a row here —
// it's matched directly via Assignment.externalId (the sheet's ConnectionID).
model ExternalSyncMapping {
  id         String         @id @default(cuid())
  source     String         @default("va_connections_sheet")
  entityType SyncEntityType @map("entity_type")
  externalId String         @map("external_id")
  internalId String         @map("internal_id")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  @@unique([source, entityType, externalId])
  @@index([internalId])
  @@map("external_sync_mappings")
}

// Raw mirror of the manager's VAConnections sheet — "load" phase only.
// Every row that has a ConnectionID gets stored here as-is on each sync run,
// regardless of whether it resolves to a real VAProfile/Client. Turning a row
// into an actual Assignment (the "connect" phase) is deliberately separate
// and not wired in yet.
model VAConnectionRecord {
  id               String   @id @default(cuid())
  connectionId     String   @unique @map("connection_id")
  status           String
  connectionType   String?  @map("connection_type")
  vaExternalId     String?  @map("va_external_id")
  vaName           String?  @map("va_name")
  clientExternalId String?  @map("client_external_id")
  clientName       String?  @map("client_name")
  department       String?
  service          String?
  hours            String?
  hoursType        String?  @map("hours_type")
  connectionDate   String?  @map("connection_date")
  startDate        String?  @map("start_date")
  terminationDate  String?  @map("termination_date")
  notes            String?
  raw              Json
  lastSyncedAt     DateTime @map("last_synced_at")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([status])
  @@index([vaName])
  @@index([clientName])
  @@map("va_connection_records")
}

model Notification {
  id                 String           @id @default(cuid())
  recipientId        String           @map("recipient_id")
  recipient          User             @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  type               NotificationType
  title              String
  message            String
  entityType         String?          @map("entity_type")
  entityId           String?          @map("entity_id")
  messageId          String?          @map("message_id")
  mentionerName      String?          @map("mentioner_name")
  mentionerAvatarUrl String?          @map("mentioner_avatar_url")
  departmentName     String?          @map("department_name")
  read               Boolean          @default(false)
  createdAt          DateTime         @default(now()) @map("created_at")

  @@index([recipientId, read, createdAt])
  @@map("notifications")
}

// ──────────────────────────────────────────────────────────────────
// MODELS — Sidebar Favorites
// ──────────────────────────────────────────────────────────────────

enum FavoriteColor {
  YELLOW
  BLUE
  RED
}

enum MessageColor {
  BLUE
  RED
  GREEN
  YELLOW
  BLACK
}

model SidebarFavorite {
  id         String        @id @default(cuid())
  userId     String        @map("user_id")
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  href       String
  label      String
  color      FavoriteColor
  isFeatured Boolean       @default(false) @map("is_featured")
  createdAt  DateTime      @default(now()) @map("created_at")

  @@unique([userId, href])
  @@index([userId])
  @@map("sidebar_favorites")
}

// ──────────────────────────────────────────────────────────────────
// MODELS — Phase V: Teams
// ──────────────────────────────────────────────────────────────────

model Team {
  id           String     @id @default(cuid())
  name         String
  departmentId String     @map("department_id")
  department   Department @relation("DepartmentTeams", fields: [departmentId], references: [id], onDelete: Cascade)

  leaderId      String? @map("leader_id")
  leader        User?   @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: SetNull)
  tempLeader1Id String? @map("temp_leader1_id")
  tempLeader1   User?   @relation("TeamTempLeader1", fields: [tempLeader1Id], references: [id], onDelete: SetNull)
  tempLeader2Id String? @map("temp_leader2_id")
  tempLeader2   User?   @relation("TeamTempLeader2", fields: [tempLeader2Id], references: [id], onDelete: SetNull)

  status    GeneralStatus @default(ACTIVE) @map("general_status")
  onHold    Boolean       @default(false) @map("on_hold")
  isActive  Boolean       @default(true) @map("is_active")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  memberships TeamMembership[]

  @@unique([name, departmentId])
  @@index([departmentId])
  @@index([leaderId])
  @@map("teams")
}

model TeamMembership {
  id        String    @id @default(cuid())
  teamId    String    @map("team_id")
  team      Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String    @map("user_id")
  user      User      @relation("TeamMember", fields: [userId], references: [id], onDelete: Cascade)
  startedAt DateTime  @default(now()) @map("started_at")
  endedAt   DateTime? @map("ended_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([teamId, userId])
  @@index([userId])
  @@map("team_memberships")
}

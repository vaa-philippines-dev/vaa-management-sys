generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  MANAGER
  VA
}

enum AssignmentType {
  REGULAR
  PROJECT
}

enum AssignmentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum SkillCategory {
  AMAZON
  WALMART
  TIKTOK_SHOP
  SHOPIFY
  GENERAL
}

enum ClientPlatform {
  AMAZON
  WALMART
  TIKTOK_SHOP
  SHOPIFY
  MULTI
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?
  role       UserRole
  department String?
  avatarUrl  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  vaProfile     VAProfile?
  managedClients Client[]      @relation("ClientManager")

  @@map("users")
}

model VAProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone      String?
  hourlyRate Decimal? @map("hourly_rate")
  notes      String?
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  skills      Skill[]      @relation("VASkills")
  assignments Assignment[]
  workLogs    WorkLog[]

  @@map("va_profiles")
}

model Skill {
  id        String        @id @default(cuid())
  name      String        @unique
  category  SkillCategory @default(GENERAL)
  createdAt DateTime      @default(now())

  vas VAProfile[] @relation("VASkills")

  @@map("skills")
}

model Client {
  id          String   @id @default(cuid())
  name        String
  contactName String?  @map("contact_name")
  contactEmail String? @map("contact_email")
  platform    ClientPlatform @default(MULTI)
  industry    String?
  notes       String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  managerId   String?  @map("manager_id")
  manager     User?    @relation("ClientManager", fields: [managerId], references: [id])

  requiredSkills String[] @map("required_skills")
  assignments    Assignment[]

  @@map("clients")
}

model Assignment {
  id           String           @id @default(cuid())
  type         AssignmentType
  status       AssignmentStatus @default(ACTIVE)
  agreedHours  Decimal          @map("agreed_hours")
  startDate    DateTime         @map("start_date")
  endDate      DateTime?        @map("end_date")
  monthlyHours Decimal?         @map("monthly_hours")
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  vaProfileId String    @map("va_profile_id")
  vaProfile   VAProfile @relation(fields: [vaProfileId], references: [id], onDelete: Cascade)

  clientId String @map("client_id")
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  workLogs WorkLog[]

  @@index([vaProfileId])
  @@index([clientId])
  @@index([status])
  @@map("assignments")
}

model WorkLog {
  id        String   @id @default(cuid())
  workDate  DateTime @map("work_date")
  hours     Decimal
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vaProfileId String    @map("va_profile_id")
  vaProfile   VAProfile @relation(fields: [vaProfileId], references: [id], onDelete: Cascade)

  assignmentId String      @map("assignment_id")
  assignment   Assignment  @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([vaProfileId])
  @@index([assignmentId])
  @@index([workDate])
  @@map("work_logs")
}